# IntelligenceMaxxxing Engine configuration (Stage 1)
# Copy to .env and adjust. Never commit real secrets.

ENGINE_ENV=development
ENGINE_HOST=127.0.0.1
ENGINE_PORT=8100
ENGINE_VERSION=0.1.0
CONSTITUTION_VERSION=1.1

# Central database is PostgreSQL. SQLite is allowed only for tests and
# very limited isolated development (never a silent production choice).
DATABASE_URL=postgresql+psycopg://intelligence:intelligence@127.0.0.1:5432/intelligence_maxxxing

LOG_LEVEL=INFO

# Migration safety (all default OFF / blocked). See docs/runbooks/MIGRATION_SAFETY.md
ENGINE_DESTRUCTIVE_MIGRATIONS_ALLOWED=false
ENGINE_MAINTENANCE_MODE=false
# ENGINE_CONFIRMED_BACKUP_ID=
