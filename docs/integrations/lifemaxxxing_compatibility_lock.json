{
  "lock_version": 2,
  "certified_at": "2026-07-20",
  "engine": {
    "api_version": "v1",
    "engine_version": "0.1.0",
    "observation_schema_version": "1.0",
    "epistemic_template": "life.sleep_threshold_productivity.v1",
    "analysis_method": "BayesianBootstrapDifferenceInMeans.v1",
    "migration": "0007_wellbeing_v2",
    "wellbeing_formula": "wellbeing_v1",
    "wellbeing_formula_version": "1.0",
    "wellbeing_formula_active": "wellbeing_v1@1.0",
    "wellbeing_formula_shadow": "wellbeing_v2@2.0.0"
  },
  "sdk": {
    "package": "intelligence-maxxxing-client",
    "version": "0.2.2",
    "python_requires": ">=3.10",
    "dependencies": ["httpx>=0.27", "pydantic>=2.7"],
    "numpy": "server-side-only"
  },
  "application": {
    "display_name": "LifeMaxxxing",
    "domain_pack": "life",
    "observed_by": "lifemaxxxing-backend",
    "scopes": [
      "SUBMIT_OBSERVATION",
      "READ_AUDIT",
      "READ_INTELLIGENCE",
      "SUBMIT_HYPOTHESIS",
      "READ_HYPOTHESIS",
      "MANAGE_EXPERIMENT",
      "READ_BELIEF",
      "READ_LEARNING"
    ]
  },
  "event_types": {
    "life.daily_check_in.completed.v1": {
      "subject": "daily_check_in",
      "knowledge_class": "OBSERVED_FACT",
      "sent_fields": [
        "happiness", "energy", "stress", "productivity", "sleep_hours",
        "calories_consumed", "calories_burned", "weight",
        "deep_work_blocks", "meetings_count",
        "gym_done", "football_played", "social_activity", "alcohol"
      ],
      "excluded_fields": ["main_work_win", "main_blocker", "notes", "source"]
    },
    "life.workout.completed.v1": {
      "subject": "workout",
      "knowledge_class": "OBSERVED_FACT",
      "sent_fields": [
        "type", "duration_minutes", "intensity", "bodyweight_kg",
        "exercise_count", "total_sets", "total_volume_kg"
      ],
      "excluded_fields": ["notes", "exercises", "title", "description"]
    }
  },
  "life_backend_endpoints": [
    "GET /api/intelligence/status",
    "POST /api/intelligence/observations/sync",
    "GET /api/intelligence/audits/{audit_id}",
    "GET /api/intelligence/hypotheses",
    "POST /api/intelligence/hypotheses/sleep-productivity",
    "GET /api/intelligence/hypotheses/{id}",
    "POST /api/intelligence/hypotheses/{id}/activate",
    "POST /api/intelligence/hypotheses/{id}/retire",
    "POST /api/intelligence/experiments/{id}/evaluate",
    "GET /api/intelligence/experiments/{id}/progress",
    "GET /api/intelligence/hypotheses/{id}/belief",
    "GET /api/intelligence/hypotheses/{id}/learning",
    "GET /api/intelligence/wellbeing/current",
    "GET /api/intelligence/wellbeing/history",
    "GET /api/intelligence/wellbeing/explanation",
    "GET /api/intelligence/wellbeing/formula",
    "POST /api/intelligence/wellbeing/feedback",
    "GET /api/intelligence/wellbeing/shadow/compare"
  ],
  "engine_wellbeing_endpoints": [
    "GET /api/v1/wellbeing/current",
    "GET /api/v1/wellbeing/history",
    "GET /api/v1/wellbeing/explanation",
    "GET /api/v1/wellbeing/formula",
    "POST /api/v1/wellbeing/feedback",
    "GET /api/v1/wellbeing/shadow/compare"
  ],
  "life_backend_error_codes": [
    "unknown_event_type", "engine_validation", "engine_conflict",
    "engine_not_found", "engine_auth", "engine_unavailable",
    "engine_unreachable", "engine_disabled", "engine_not_configured",
    "engine_error", "invalid_parameters"
  ],
  "gates": {
    "stage3_epistemic": "scripts/audit/run_stage3_epistemic_gates.ps1",
    "cross_repo_stage2": "scripts/audit/run_lifemaxxxing_contract_gates.ps1",
    "sdk_build": "scripts/sdk/build_client_sdk.ps1",
    "sdk_certification": "scripts/sdk/test_client_sdk.ps1",
    "rebuild_epistemic": "scripts/projections/rebuild_epistemic.ps1",
    "verify_epistemic": "scripts/projections/verify_epistemic.ps1"
  }
}
