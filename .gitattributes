# The constitutional foundation is frozen and hashed (SHA-256 manifest).
# Git must never rewrite its bytes (no end-of-line conversion on checkout).
docs/constitutional/** -text

# Keep repository content stable across platforms.
*.py text eol=lf
*.toml text eol=lf
*.md text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.ini text eol=lf
*.mako text eol=lf
*.ps1 text eol=crlf
